{
  "compilerOptions": {
    "module": "commonjs",
    "target": "esnext",
    "types": ["multer"],
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true
  }
}
